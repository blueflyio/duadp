# UADP Reference Node Configuration
# Copy this file to .env and customize for your deployment

# HTTP port
PORT=4200

# Public base URL (used in discovery manifest and GAID generation)
UADP_BASE_URL=http://localhost:4200

# Human-readable node name
UADP_NODE_NAME=My UADP Node

# DID identifier for this node (did:web recommended)
UADP_NODE_ID=did:web:localhost

# SQLite database path
DB_PATH=./data/uadp.db

# Domain used in seed data DIDs and endpoints (seed.ts only)
# UADP_SEED_DOMAIN=example.uadp.dev
