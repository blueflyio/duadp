{
  "private": true,
  "name": "duadp",
  "description": "DUADP monorepo — spec, SDK, and reference node",
  "scripts": {
    "build": "npm run build --prefix sdk/typescript",
    "test": "npm test --prefix sdk/typescript",
    "publish": "cd sdk/typescript && npm publish --access public",
    "publish:ts": "cd sdk/typescript && npm publish --access public",
    "publish:py": "cd sdk/python && python -m build && twine upload dist/*",
    "publish:all": "npm run publish:ts && npm run publish:py",
    "seed": "npm run seed --prefix reference-node",
    "start": "npm run dev --prefix reference-node"
  },
  "overrides": {
    "hono": "4.12.7"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  }
}
