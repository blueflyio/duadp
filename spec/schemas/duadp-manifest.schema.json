{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openstandardagents.org/spec/duadp/v0.2/schemas/duadp-manifest.schema.json",
  "title": "DUADP Node Manifest",
  "description": "Schema for /.well-known/duadp.json — the discovery manifest for a DUADP node.",
  "type": "object",
  "required": ["protocol_version", "node_name", "endpoints"],
  "properties": {
    "protocol_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the DUADP protocol this node implements."
    },
    "node_id": {
      "type": "string",
      "description": "DID or URI uniquely identifying this node (e.g., did:web:example.com)."
    },
    "node_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Human-readable name of this DUADP node."
    },
    "node_description": {
      "type": "string",
      "maxLength": 1024,
      "description": "Short description of the node's purpose."
    },
    "contact": {
      "type": "string",
      "description": "Admin contact email or URL."
    },
    "endpoints": {
      "type": "object",
      "description": "Map of capability name to relative or absolute URL.",
      "properties": {
        "skills": { "type": "string", "description": "URL for /api/v1/skills" },
        "agents": { "type": "string", "description": "URL for /api/v1/agents" },
        "tools": { "type": "string", "description": "URL for /api/v1/tools" },
        "federation": { "type": "string", "description": "URL for /api/v1/federation" },
        "validate": { "type": "string", "description": "URL for /api/v1/validate" },
        "publish": { "type": "string", "description": "URL for /api/v1/publish" },
        "governance": { "type": "string", "description": "URL for /api/v1/governance" },
        "provenance": { "type": "string", "description": "URL for /api/v1/provenance" },
        "revocations": { "type": "string", "description": "URL for /api/v1/revocations" },
        "audit_log": { "type": "string", "description": "URL for /api/v1/governance/audit" },
        "events": { "type": "string", "description": "URL for /api/v1/events" },
        "identity": { "type": "string", "description": "URL for /api/v1/identity" }
      },
      "anyOf": [
        { "required": ["skills"] },
        { "required": ["agents"] },
        { "required": ["tools"] }
      ],
      "additionalProperties": { "type": "string" }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["skills", "agents", "tools", "federation", "validation", "publishing", "governance", "provenance", "revocations", "audit", "events", "identity"]
      },
      "description": "List of supported DUADP capabilities."
    },
    "identity": {
      "type": "object",
      "properties": {
        "did": { "type": "string", "description": "Decentralized Identifier (did:web: recommended)" },
        "public_key": { "type": "string", "description": "PEM-encoded public key" }
      },
      "description": "Node identity for signature verification."
    },
    "public_key": {
      "type": "string",
      "description": "DEPRECATED. Use identity.public_key instead."
    },
    "ossa_versions": {
      "type": "array",
      "items": { "type": "string", "pattern": "^v\\d+\\.\\d+$" },
      "description": "Supported OSSA specification versions."
    },
    "federation": {
      "type": "object",
      "properties": {
        "gossip": { "type": "boolean", "description": "Whether this node supports gossip protocol." },
        "max_hops": { "type": "integer", "minimum": 0, "default": 2, "description": "Max peer propagation depth." }
      },
      "description": "Federation configuration."
    },
    "governance": {
      "$ref": "#/$defs/NodeGovernance",
      "description": "Node governance declarations (NIST GOVERN function)."
    }
  },
  "$defs": {
    "OssaMetadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" },
        "uri": { "type": "string", "description": "GAID — agent://namespace/type/name" },
        "category": { "type": "string" },
        "trust_tier": { "type": "string", "enum": ["official", "verified-signature", "signed", "community", "experimental"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "created": { "type": "string", "format": "date-time" },
        "updated": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "ResourceSignature": {
      "type": "object",
      "required": ["algorithm", "value", "signer"],
      "properties": {
        "algorithm": { "type": "string", "enum": ["Ed25519", "ES256"] },
        "value": { "type": "string" },
        "signer": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "NodeGovernance": {
      "type": "object",
      "description": "Node governance declarations (NIST GOVERN function).",
      "properties": {
        "compliance_frameworks": { "type": "array", "items": { "type": "string" }, "description": "e.g., NIST-AI-RMF, SOC2, FedRAMP, ISO-42001" },
        "risk_tolerance": { "type": "string", "enum": ["strict", "moderate", "permissive"] },
        "data_classification": { "type": "string", "enum": ["public", "internal", "confidential", "restricted"] },
        "review_policy": { "type": "string", "enum": ["manual", "automated", "hybrid"] },
        "audit_retention_days": { "type": "integer", "minimum": 0 }
      }
    },
    "ResourceProvenance": {
      "type": "object",
      "description": "Supply chain provenance (NIST SP 800-218A).",
      "properties": {
        "publisher": { "$ref": "#/$defs/ProvenancePublisher" },
        "build": { "$ref": "#/$defs/BuildInfo" },
        "sbom": { "$ref": "#/$defs/SBOM" },
        "attestations": { "type": "array", "items": { "$ref": "#/$defs/Attestation" } }
      }
    },
    "ProvenancePublisher": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "organization": { "type": "string" },
        "verified": { "type": "boolean" }
      }
    },
    "BuildInfo": {
      "type": "object",
      "description": "SLSA-style build provenance.",
      "properties": {
        "builder": { "type": "string" },
        "source_repo": { "type": "string", "format": "uri" },
        "commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "build_time": { "type": "string", "format": "date-time" },
        "reproducible": { "type": "boolean" }
      }
    },
    "SBOM": {
      "type": "object",
      "description": "Software Bill of Materials.",
      "properties": {
        "format": { "type": "string", "enum": ["spdx", "cyclonedx"] },
        "components": { "type": "array", "items": { "$ref": "#/$defs/SBOMComponent" } }
      }
    },
    "SBOMComponent": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "type": { "type": "string", "enum": ["model", "library", "framework", "tool", "dataset", "runtime"] },
        "supplier": { "type": "string" },
        "license": { "type": "string" },
        "hash": { "type": "string" }
      }
    },
    "Attestation": {
      "type": "object",
      "required": ["type", "issuer", "result"],
      "description": "Third-party attestation (NIST GOVERN 1.7).",
      "properties": {
        "type": { "type": "string", "enum": ["security-audit", "compliance-review", "performance-test", "safety-evaluation", "red-team"] },
        "issuer": { "type": "string" },
        "issued_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "result": { "type": "string", "enum": ["pass", "conditional-pass", "fail"] },
        "details_url": { "type": "string", "format": "uri" }
      }
    },
    "ResourceRisk": {
      "type": "object",
      "description": "NIST AI RMF risk assessment (MAP 5.1, MEASURE 1.1).",
      "properties": {
        "level": { "type": "string", "enum": ["critical", "high", "moderate", "low", "minimal"] },
        "impact": {
          "type": "object",
          "properties": {
            "people": { "type": "string", "enum": ["critical", "high", "moderate", "low", "minimal", "none"] },
            "organizations": { "type": "string", "enum": ["critical", "high", "moderate", "low", "minimal", "none"] },
            "ecosystems": { "type": "string", "enum": ["critical", "high", "moderate", "low", "minimal", "none"] }
          }
        },
        "autonomy_level": { "type": "string", "enum": ["fully-autonomous", "supervised", "human-in-the-loop", "advisory"] },
        "data_sensitivity": { "type": "string", "enum": ["public", "internal", "confidential", "restricted"] },
        "known_limitations": { "type": "array", "items": { "type": "string" } },
        "mitigations": { "type": "array", "items": { "type": "string" } },
        "nist_controls": { "type": "array", "items": { "$ref": "#/$defs/NISTControl" } }
      }
    },
    "NISTControl": {
      "type": "object",
      "required": ["control_id", "status"],
      "description": "NIST SP 800-53 control mapping.",
      "properties": {
        "control_id": { "type": "string", "description": "e.g., AC-6, SA-4, SR-3" },
        "status": { "type": "string", "enum": ["implemented", "partially-implemented", "planned", "not-applicable"] },
        "evidence": { "type": "string" }
      }
    },
    "Revocation": {
      "type": "object",
      "required": ["gaid", "reason", "revoked_at"],
      "description": "Revoked resource (NIST SI-7, CM-3).",
      "properties": {
        "gaid": { "type": "string" },
        "resource_name": { "type": "string" },
        "reason": { "type": "string", "enum": ["security-vulnerability", "policy-violation", "publisher-request", "expired", "superseded"] },
        "severity": { "type": "string", "enum": ["critical", "high", "moderate", "low"] },
        "revoked_at": { "type": "string", "format": "date-time" },
        "revoked_by": { "type": "string" },
        "superseded_by": { "type": "string" }
      }
    },
    "AuditEvent": {
      "type": "object",
      "required": ["event_type", "timestamp"],
      "description": "Governance audit trail entry (NIST AU-2, AU-3).",
      "properties": {
        "event_id": { "type": "string" },
        "event_type": { "type": "string", "enum": ["publish", "revoke", "update", "peer_added", "peer_removed", "access", "validation", "risk_change"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "actor": { "type": "string" },
        "gaid": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "SyncChange": {
      "type": "object",
      "required": ["action", "resource_type", "gaid", "timestamp"],
      "description": "Single change in incremental sync.",
      "properties": {
        "action": { "type": "string", "enum": ["created", "updated", "revoked", "deleted"] },
        "resource_type": { "type": "string", "enum": ["skill", "agent", "tool"] },
        "gaid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "content_hash": { "type": "string" },
        "resource": { "$ref": "#/$defs/OssaResource" }
      }
    },
    "OssaResource": {
      "type": "object",
      "required": ["apiVersion", "kind", "metadata"],
      "properties": {
        "apiVersion": { "type": "string" },
        "kind": { "type": "string" },
        "metadata": { "$ref": "#/$defs/OssaMetadata" },
        "spec": { "type": "object", "additionalProperties": true },
        "signature": { "$ref": "#/$defs/ResourceSignature" },
        "provenance": { "$ref": "#/$defs/ResourceProvenance" },
        "risk": { "$ref": "#/$defs/ResourceRisk" },
        "content_hash": { "type": "string" }
      }
    },
    "AgentIdentity": {
      "type": "object",
      "required": ["gaid", "did"],
      "description": "Agent identity record.",
      "properties": {
        "gaid": { "type": "string" },
        "did": { "type": "string" },
        "dns_record": {
          "type": "object",
          "required": ["domain", "record_name", "record_value"],
          "properties": {
            "domain": { "type": "string" },
            "record_name": { "type": "string" },
            "record_value": { "type": "string" }
          }
        },
        "service_account": {
          "type": "object",
          "required": ["type", "provider"],
          "properties": {
            "type": { "type": "string", "enum": ["bot", "service-account", "machine-identity"] },
            "provider": { "type": "string" },
            "username": { "type": "string" },
            "scopes": { "type": "array", "items": { "type": "string" } }
          }
        },
        "keys": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "public_key", "purpose"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["Ed25519", "ES256", "RSA"] },
              "public_key": { "type": "string" },
              "purpose": { "type": "string", "enum": ["signing", "authentication", "encryption"] },
              "created": { "type": "string", "format": "date-time" },
              "expires": { "type": "string", "format": "date-time" }
            }
          }
        },
        "verification_methods": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PaginationMeta": {
      "type": "object",
      "required": ["total", "page", "limit", "node_name"],
      "properties": {
        "total": { "type": "integer" },
        "page": { "type": "integer" },
        "limit": { "type": "integer" },
        "node_name": { "type": "string" },
        "node_id": { "type": "string" },
        "federated": { "type": "boolean" },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "node_id": { "type": "string" },
              "node_name": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        }
      }
    }
  }
}
