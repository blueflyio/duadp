{
  "name": "DUADP Federation API",
  "apiVersion": "1.0",
  "description": "DUADP peer discovery and federation",
  "operations": {
    "GetManifest": {
      "httpMethod": "GET",
      "uri": "/.well-known/duadp.json",
      "summary": "Get DUADP manifest from peer",
      "responseModel": "getResponse"
    },
    "GetAgents": {
      "httpMethod": "GET",
      "uri": "/api/v1/agents",
      "summary": "List agents from peer",
      "responseModel": "getResponse"
    },
    "GetSkills": {
      "httpMethod": "GET",
      "uri": "/api/v1/skills",
      "summary": "List skills from peer",
      "responseModel": "getResponse"
    }
  },
  "models": {
    "getResponse": {
      "type": "object",
      "additionalProperties": {
        "location": "json"
      }
    }
  }
}
