<?php

/**
 * @file
 * DUADP Discovery module — config entities for DUADP node registration.
 *
 * Allows any Drupal site to declare itself a DUADP federation node and
 * expose drupal/ai plugins (agents, skills, tools) to the discovery mesh.
 */

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_help().
 */
function duadp_discovery_help($route_name, \Drupal\Core\Routing\RouteMatchInterface $route_match) {
  if ($route_name === 'help.page.duadp_discovery') {
    return '<p>' . t('Provides config entities so this Drupal site can register as a DUADP federation node. Configure node registration at <a href=":url">DUADP Discovery Settings</a>.', [':url' => \Drupal\Core\Url::fromRoute('duadp_discovery.settings')->toString()]) . '</p>';
  }
}

/**
 * Implements hook_cron().
 *
 * Syncs the site's drupal/ai plugin catalogue to the DUADP registry node
 * and refreshes federation peer health on each cron run.
 */
function duadp_discovery_cron() {
  /** @var \Drupal\duadp_discovery\DuadpDiscoveryService $service */
  $service = \Drupal::service('duadp_discovery.service');
  $service->syncPluginCatalogue();
  $service->refreshPeerHealth();
  \Drupal::logger('duadp_discovery')->info('DUADP discovery sync completed on cron.');
}

/**
 * Implements hook_entity_insert() for agent nodes.
 *
 * When a content entity tagged as an OSSA agent is saved, publish it
 * immediately to the configured DUADP node.
 */
function duadp_discovery_entity_insert(EntityInterface $entity) {
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'ossa_agent') {
    /** @var \Drupal\duadp_discovery\DuadpDiscoveryService $service */
    $service = \Drupal::service('duadp_discovery.service');
    $service->publishAgentNode($entity);
  }
}
