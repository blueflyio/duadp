{
  "name": "@bluefly/duadp",
  "version": "0.1.0",
  "description": "DUADP — Decentralized Universal AI Discovery Protocol SDK for TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "duadp": "dist/cli.js"
  },
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/blueflyio/ossa/lab/duadp.git",
    "directory": "sdk/typescript"
  },
  "homepage": "https://openstandardagents.org/duadp/",
  "bugs": {
    "url": "https://gitlab.com/blueflyio/ossa/lab/duadp/-/issues"
  },
  "author": "Bluefly <hello@bluefly.io>",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./validate": {
      "import": "./dist/validate.js",
      "types": "./dist/validate.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto.js",
      "types": "./dist/crypto.d.ts"
    },
    "./did": {
      "import": "./dist/did.js",
      "types": "./dist/did.d.ts"
    },
    "./conformance": {
      "import": "./dist/conformance.js",
      "types": "./dist/conformance.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "duadp",
    "ossa",
    "agent",
    "discovery",
    "federation",
    "mcp",
    "ai"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "dependencies": {
    "canonicalize": "^2.1.0",
    "did-resolver": "^4.1.0",
    "key-did-resolver": "^4.0.0",
    "web-did-resolver": "^2.0.32"
  }
}
